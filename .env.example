# Runtime
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_AUTH_TOKEN=
API_DOCS_ENABLED=true
DATABASE_URL=sqlite:///./data/app.db
WORKER_POLL_SECONDS=2
JOB_LEASE_SECONDS=300

# Vector store
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=rag_assistant
QDRANT_VECTOR_SIZE=384

# Retrieval
TOP_K=5
RELEVANCE_MIN_LEXICAL_SCORE=0.12
RELEVANCE_MIN_DENSE_SCORE=0.92
RELEVANCE_MIN_FINAL_SCORE=0.12
RELEVANCE_MIN_MEANINGFUL_TERMS=2
DEFAULT_CHUNKER_TYPE=recursive
DEFAULT_CHUNK_SIZE=700
DEFAULT_CHUNK_OVERLAP=120
MAX_CHUNK_SIZE=1400
MAX_UPLOAD_FILE_BYTES=26214400
MAX_URL_BYTES=5242880
MAX_SITEMAP_URLS=100
ACCEPTED_FILE_EXTENSIONS=.pdf,.docx,.md,.markdown
ALLOW_PRIVATE_URLS=false
URL_ALLOWED_DOMAINS=
URL_BLOCKED_DOMAINS=

# Embeddings
EMBED_PROVIDER=mock
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Generation
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b

# Evaluation
EVAL_DATASET_DIR=./evals/datasets
EVAL_FAITHFULNESS_USE_LLM=false
